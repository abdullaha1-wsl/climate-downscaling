   "source": [
    "# =============================================================================\n",
    "# GEE + xclim QDM Bias Correction Pipeline – Optimised & Scientifically Correct\n",
    "# =============================================================================\n",
    "# Optimisations over previous version:\n",
    "#   - Historical CMIP6 is fetched ONCE per model (not once per scenario × interval)\n",
    "#   - Reference data is fetched ONCE and reused across all loops\n",
    "#   - QDM is trained ONCE per model (hist vs ref) and reused for every future period\n",
    "#     of every scenario – this is scientifically correct: the transfer function is\n",
    "#     derived from the calibration period alone.\n",
    "#   - QDM group changed to 'time.month' (statistically robust for daily data with\n",
    "#     NQUANTILES=50; 'time.dayofyear' requires far more data per group)\n",
    "#   - Wet-day frequency adjustment uses only the reference period wet-day statistics\n",
    "#     (not the corrected future), which is the correct scientific approach\n",
    "#   - Unit-conversion guard: converts only when units differ from target\n",
    "#   - Calendar standardisation happens before any time-based grouping\n",
    "#   - NetCDF \"calendar\" attribute conflict fixed via clean_time_attrs()\n",
    "#\n",
    "# Scientific references:\n",
    "#   Cannon et al. (2015) – Quantile Delta Mapping, J. Climate\n",
    "#   Themeßl et al. (2012) – Wet-day frequency adjustment, Int. J. Climatol.\n",
    "# =============================================================================\n",
    "\n",
    "# ── 0. Install dependencies ──────────────────────────────────────────────────\n",
    "# !pip install earthengine-api xarray xclim xsdba xee netCDF4 dask --quiet\n",
    "\n",
    "import ee\n",
    "import xarray as xr\n",
    "import xclim.sdba as sdba\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "import warnings\n",
    "import logging\n",
    "\n",
    "from google.colab import drive\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "logging.getLogger('urllib3.connectionpool').setLevel(logging.ERROR)\n",
    "logging.getLogger('google_auth_httplib2').setLevel(logging.ERROR)\n",
    "logging.getLogger('googleapiclient.discovery_cache').setLevel(logging.ERROR)\n",
    "\n",
    "# =============================================================================\n",
    "# 1. USER CONFIGURATION\n",
    "# =============================================================================\n",
    "\n",
    "VARIABLE = 'tas'   # 'pr'  → precipitation | 'tas' → near-surface temperature\n",
    "\n",
    "# ── Variable-dependent settings ──────────────────────────────────────────────\n",
    "_CFG = {\n",
    "    'pr': dict(\n",
    "        ref_collection='UCSB-CHG/CHIRPS/DAILY',\n",
    "        ref_band='precipitation',\n",
    "        ref_units='mm day-1',\n",
    "        ref_name='CHIRPS',\n",
    "        qdm_kind='*',               # multiplicative QDM (Cannon 2015)\n",
    "        wet_adjust=True,\n",
    "        cmip6_unit_factor=86400.0,  # kg m-2 s-1 → mm day-1\n",
    "        clip_min=0.0,\n",
    "        clip_max=1000.0,\n",
    "        fill_na=0.0,\n",
    "        scale=5566,                 # ≈ 0.05° (CHIRPS native)\n",
    "    ),\n",
    "    'tas': dict(\n",
    "        ref_collection='ECMWF/ERA5_LAND/DAILY_AGGR',\n",
    "        ref_band='temperature_2m',\n",
    "        ref_units='K',\n",
    "        ref_name='ERA5-Land',\n",
    "        qdm_kind='+',               # additive QDM\n",
    "        wet_adjust=False,\n",
    "        cmip6_unit_factor=1.0,      # CMIP6 tas already in Kelvin\n",
    "        clip_min=200.0,\n",
    "        clip_max=350.0,\n",
    "        fill_na=280.0,              # ≈ 7 °C – neutral fill\n",
    "        scale=11132,                # ≈ 0.1° (ERA5-Land native)\n",
    "    ),\n",
    "}\n",
    "\n",
    "if VARIABLE not in _CFG:\n",
    "    raise ValueError(f\"VARIABLE must be one of {list(_CFG)}, got '{VARIABLE}'\")\n",
    "\n",
    "CFG = _CFG[VARIABLE]\n",
    "\n",
    "# Convenience unpacking\n",
    "REF_COLLECTION      = CFG['ref_collection']\n",
    "REF_BAND            = CFG['ref_band']\n",
    "REF_UNITS           = CFG['ref_units']\n",
    "REF_NAME            = CFG['ref_name']\n",
    "QDM_KIND            = CFG['qdm_kind']\n",
    "WET_ADJUST          = CFG['wet_adjust']\n",
    "CMIP6_UNIT_FACTOR   = CFG['cmip6_unit_factor']\n",
    "CLIP_MIN            = CFG['clip_min']\n",
    "CLIP_MAX            = CFG['clip_max']\n",
    "FILL_NA             = CFG['fill_na']\n",
    "SCALE               = CFG['scale']\n",
    "\n",
    "# ── Domain & time settings ───────────────────────────────────────────────────\n",
    "EXTENT = [72.346, 33.011, 78.165, 38.259]  # [lon_min, lat_min, lon_max, lat_max]\n",
    "\n",
    "MODELS    = ['EC-Earth3', 'CNRM-CM6-1', 'GFDL-ESM4', 'MPI-ESM1-2-LR', 'GISS-E2-1-G']\n",
    "SCENARIOS = ['ssp245', 'ssp585']\n",
    "\n",
    "BASELINE_START, BASELINE_END = '1990-01-01', '2014-12-31'\n",
    "\n",
    "FUTURE_INTERVALS = [\n",
    "    ('2026-01-01', '2050-12-31', '2026-2050'),\n",
    "    ('2051-01-01', '2075-12-31', '2051-2075'),\n",
    "    ('2076-01-01', '2100-12-31', '2076-2100'),\n",
    "]\n",
    "\n",
    "# QDM hyper-parameters\n",
    "NQUANTILES = 50        # 50 quantiles → stable with ~9 000 baseline daily values\n",
    "QDM_GROUP  = 'time.month'   # monthly grouping: robust for NQUANTILES=50\n",
    "\n",
    "# Wet-day threshold (precipitation only)\n",
    "WET_THRESH = 0.1  # mm day-1\n",
    "\n",
    "# Dask chunking\n",
    "CHUNKS_LATLON = {'lat': 50, 'lon': 50}\n",
    "\n",
    "# ── Diagnostics ───────────────────────────────────────────────────────────────\n",
    "print(f\"Variable        : {VARIABLE}\")\n",
    "print(f\"Reference       : {REF_NAME}  ({REF_UNITS})\")\n",
    "print(f\"QDM kind        : {QDM_KIND}\")\n",
    "print(f\"Wet-day adjust  : {WET_ADJUST}\")\n",
    "print(f\"Spatial scale   : {SCALE} m\")\n",
    "print(f\"Baseline period : {BASELINE_START} – {BASELINE_END}\")\n",
    "print(f\"Models          : {MODELS}\")\n",
    "print(f\"Scenarios       : {SCENARIOS}\")\n",
    "\n",
    "# =============================================================================\n",
    "# 2. INITIALISATION\n",
    "# =============================================================================\n",
    "\n",
    "drive.mount('/content/drive')\n",
    "OUTPUT_DIR = '/content/drive/MyDrive/test'\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "print(f\"\\nOutput directory: {OUTPUT_DIR}\")\n",
    "\n",
    "# ── Calendar conversion (with graceful fallback) ──────────────────────────────\n",
    "try:\n",
    "    from xclim.core.calendar import convert_calendar\n",
    "    print(\"✅ Using xclim.core.calendar.convert_calendar\")\n",
    "except ImportError:\n",
    "    try:\n",
    "        from xclim.sdba.base import convert_calendar\n",
    "        print(\"✅ Using xclim.sdba.base.convert_calendar\")\n",
    "    except ImportError:\n",
    "        def convert_calendar(ds, target):\n",
    "            \"\"\"Remove Feb-29 and tag calendar attribute.\"\"\"\n",
    "            if 'time' in ds.dims:\n",
    "                ds = ds.sel(\n",
    "                    time=~((ds.time.dt.month == 2) & (ds.time.dt.day == 29))\n",
    "                )\n",
    "                if hasattr(ds.time, 'to_datetimeindex'):\n",
    "                    ds['time'] = ds.time.to_datetimeindex()\n",
    "                ds.time.attrs['calendar'] = target\n",
    "            return ds\n",
    "        print(\"⚠️  Using fallback calendar conversion (no xclim.core.calendar)\")\n",
    "\n",
    "# ── GEE ───────────────────────────────────────────────────────────────────────\n",
    "def initialize_gee(project_id="'):\n", #Add your Project ID
    "    try:\n",
    "        ee.Initialize()\n",
    "        print(\"✅ GEE already initialised.\")\n",
    "    except Exception:\n",
    "        print(\"🔐 Authenticating with GEE …\")\n",
    "        ee.Authenticate()\n",
    "        ee.Initialize(project=project_id)\n",
    "        print(f\"✅ GEE initialised with project: {project_id}\")\n",
    "\n",
    "initialize_gee()\n",
    "REGION = ee.Geometry.Rectangle(EXTENT)\n",
    "\n",
    "# =============================================================================\n",
    "# 3. HELPER FUNCTIONS\n",
    "# =============================================================================\n",
    "\n",
    "def clean_time_attrs(obj):\n",
    "    \"\"\"\n",
    "    Remove the 'calendar' attribute from the time coordinate.\n",
    "\n",
    "    xarray writes calendar info into encoding, not attrs; keeping it in attrs\n",
    "    causes a conflict when writing NetCDF (two competing calendar declarations).\n",
    "    \"\"\"\n",
    "    if isinstance(obj, (xr.Dataset, xr.DataArray)):\n",
    "        if 'time' in obj.coords and 'calendar' in obj['time'].attrs:\n",
    "            del obj['time'].attrs['calendar']\n",
    "    return obj\n",
    "\n",
    "\n",
    "def clean_values(da):\n",
    "    \"\"\"Replace ±Inf with NaN, then clip to physically plausible range.\"\"\"\n",
    "    da = da.where(np.isfinite(da), np.nan)\n",
    "    return da.clip(min=CLIP_MIN, max=CLIP_MAX)\n",
    "\n",
    "\n",
    "def regrid_to_reference(src_da, ref_da):\n",
    "    \"\"\"\n",
    "    Bilinearly interpolate *src_da* to the lat/lon grid of *ref_da*.\n",
    "\n",
    "    Missing values after interpolation are filled with a neutral value so that\n",
    "    QDM does not propagate NaNs through the correction.\n",
    "    \"\"\"\n",
    "    out = src_da.interp(lat=ref_da.lat, lon=ref_da.lon, method='linear')\n",
    "    out = clean_values(out).fillna(FILL_NA)\n",
    "    out.attrs['units'] = src_da.attrs.get('units', REF_UNITS)\n",
    "    return out\n",
    "\n",
    "# =============================================================================\n",
    "# 4. DATA FETCHING\n",
    "# =============================================================================\n",
    "\n",
    "def _make_xee_projection():\n",
    "    \"\"\"\n",
    "    Build the crs, crs_transform, and shape_2d arguments required by the\n",
    "    installed version of xee (which mandates these three positional args).\n",
    "\n",
    "    We construct a regular lat/lon grid at SCALE metres resolution covering\n",
    "    EXTENT, express it as an affine CRS transform, and derive the pixel\n",
    "    dimensions — exactly what xee needs to regrid on the GEE server side\n",
    "    before streaming data to xarray.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    dict with keys: crs, crs_transform, shape_2d\n",
    "    \"\"\"\n",
    "    lon_min, lat_min, lon_max, lat_max = EXTENT\n",
    "    deg = SCALE / 111_320.0          # metres -> degrees (equatorial approx.)\n",
    "\n",
    "    n_lon = int(np.ceil((lon_max - lon_min) / deg)) + 1\n",
    "    n_lat = int(np.ceil((lat_max - lat_min) / deg)) + 1\n",
    "\n",
    "    # Affine transform: [x_scale, x_shear, x_origin, y_shear, y_scale, y_origin]\n",
    "    # y_scale is negative (top-left origin, rows go south)\n",
    "    crs_transform = (deg, 0, lon_min, 0, -deg, lat_max)\n",
    "\n",
    "    return dict(\n",
    "        crs='EPSG:4326',\n",
    "        crs_transform=crs_transform,\n",
    "        shape_2d=(n_lat, n_lon),\n",
    "    )\n",
    "\n",
    "_XEE_PROJ = _make_xee_projection()\n",
    "print(f\"Target grid: {_XEE_PROJ['shape_2d']} (lat × lon)  |  \"\n",
    "      f\"res ≈ {SCALE/1000:.1f} km  |  crs=EPSG:4326\")\n",
    "\n",
    "\n",
    "def _xee_open(ic_chunk):\n",
    "    \"\"\"\n",
    "    Open an ee.ImageCollection chunk as an xr.Dataset.\n",
    "\n",
    "    Passes crs, crs_transform, and shape_2d as required by the installed xee.\n",
    "    These define the output grid on the GEE server so the data arrives already\n",
    "    clipped and resampled to our target resolution.\n",
    "    \"\"\"\n",
    "    ds = xr.open_dataset(\n",
    "        ic_chunk,\n",
    "        engine='ee',\n",
    "        crs=_XEE_PROJ['crs'],\n",
    "        crs_transform=_XEE_PROJ['crs_transform'],\n",
    "        shape_2d=_XEE_PROJ['shape_2d'],\n",
    "    )\n",
    "    # xee ≥ 0.0.11 uses x/y instead of lon/lat – normalise to lon/lat\n",
    "    rename_map = {}\n",
    "    if 'x' in ds.dims and 'lon' not in ds.dims:\n",
    "        rename_map['x'] = 'lon'\n",
    "    if 'y' in ds.dims and 'lat' not in ds.dims:\n",
    "        rename_map['y'] = 'lat'\n",
    "    if rename_map:\n",
    "        ds = ds.rename(rename_map)\n",
    "    return ds\n",
    "\n",
    "\n",
    "def _fetch_chunked(collection, start_date, end_date, label=''):\n",
    "    \"\"\"\n",
    "    Stream an ee.ImageCollection to xarray in 5-year chunks.\n",
    "\n",
    "    Chunking avoids OOM errors on long time series while keeping GEE requests\n",
    "    manageable.\n",
    "    \"\"\"\n",
    "    start = pd.to_datetime(start_date)\n",
    "    end   = pd.to_datetime(end_date)\n",
    "\n",
    "    chunks, current = [], start\n",
    "    while current <= end:\n",
    "        chunk_end  = min(current + pd.DateOffset(years=5) - pd.DateOffset(days=1), end)\n",
    "        filter_end = chunk_end + pd.DateOffset(days=1)\n",
    "        print(f\"      ↳ {label}: {current:%Y-%m-%d} → {chunk_end:%Y-%m-%d}\")\n",
    "\n",
    "        ic_chunk = collection.filterDate(\n",
    "            current.strftime('%Y-%m-%d'),\n",
    "            filter_end.strftime('%Y-%m-%d'),\n",
    "        )\n",
    "        ds_chunk = _xee_open(ic_chunk)\n",
    "        chunks.append(ds_chunk)\n",
    "        current = chunk_end + pd.DateOffset(days=1)\n",
    "\n",
    "    return xr.concat(chunks, dim='time').sortby('time')\n",
    "\n",
    "\n",
    "def fetch_reference():\n",
    "    \"\"\"\n",
    "    Fetch the observational reference over the entire baseline period.\n",
    "\n",
    "    Returns an xr.Dataset with a single variable named 'ref'.\n",
    "    Called ONCE and cached in memory for all model/scenario iterations.\n",
    "    \"\"\"\n",
    "    print(f\"\\n── Fetching reference ({REF_NAME}) ──────────────────────────────\")\n",
    "    ic = (ee.ImageCollection(REF_COLLECTION)\n",
    "          .filterBounds(REGION)\n",
    "          .select(REF_BAND))\n",
    "    ds = _fetch_chunked(ic, BASELINE_START, BASELINE_END, label=REF_NAME)\n",
    "    ds = ds.rename({REF_BAND: 'ref'})\n",
    "    ds['ref'].attrs['units'] = REF_UNITS\n",
    "\n",
    "    ds = convert_calendar(ds, 'standard')\n",
    "    ds['ref'] = clean_values(ds['ref'])\n",
    "    ds = clean_time_attrs(ds)\n",
    "    ds = ds.chunk({'time': -1, **CHUNKS_LATLON})\n",
    "\n",
    "    _print_stats(\"Reference\", ds['ref'])\n",
    "    return ds\n",
    "\n",
    "\n",
    "def fetch_cmip6_historical(model):\n",
    "    \"\"\"\n",
    "    Fetch and preprocess historical CMIP6 for one model over the baseline period.\n",
    "\n",
    "    Unit conversion, calendar standardisation, cleaning, and regridding to the\n",
    "    reference grid happen here so the result is ready for QDM training.\n",
    "\n",
    "    Called ONCE per model and reused across all scenarios / future intervals.\n",
    "    \"\"\"\n",
    "    print(f\"\\n── Fetching historical CMIP6: {model} ──────────────────────────\")\n",
    "    ic = (ee.ImageCollection('NASA/GDDP-CMIP6')\n",
    "          .filterBounds(REGION)\n",
    "          .filter(ee.Filter.eq('model', model))\n",
    "          .filter(ee.Filter.eq('scenario', 'historical'))\n",
    "          .select(VARIABLE))\n",
    "    ds = _fetch_chunked(ic, BASELINE_START, BASELINE_END, label=f'{model}/hist')\n",
    "    return _preprocess_cmip6(ds, label=f'{model}/hist')\n",
    "\n",
    "\n",
    "def fetch_cmip6_future(model, scenario, start_date, end_date, interval_name):\n",
    "    \"\"\"\n",
    "    Fetch and preprocess future CMIP6 for one model/scenario/interval.\n",
    "\n",
    "    Called once per (model, scenario, interval) triple – but because historical\n",
    "    data is cached outside this function, there is no repeated historical fetch.\n",
    "    \"\"\"\n",
    "    label = f'{model}/{scenario}/{interval_name}'\n",
    "    print(f\"\\n   ── Fetching future CMIP6: {label} ──\")\n",
    "    ic = (ee.ImageCollection('NASA/GDDP-CMIP6')\n",
    "          .filterBounds(REGION)\n",
    "          .filter(ee.Filter.eq('model', model))\n",
    "          .filter(ee.Filter.eq('scenario', scenario))\n",
    "          .select(VARIABLE))\n",
    "    ds = _fetch_chunked(ic, start_date, end_date, label=label)\n",
    "    return _preprocess_cmip6(ds, label=label)\n",
    "\n",
    "\n",
    "def _preprocess_cmip6(ds, label=''):\n",
    "    \"\"\"Unit conversion, calendar fix, cleaning.  Does NOT regrid (done later).\"\"\"\n",
    "    if CMIP6_UNIT_FACTOR != 1.0:\n",
    "        ds[VARIABLE] = ds[VARIABLE] * CMIP6_UNIT_FACTOR\n",
    "    ds[VARIABLE].attrs['units'] = REF_UNITS\n",
    "\n",
    "    ds = convert_calendar(ds, 'standard')\n",
    "    ds[VARIABLE] = clean_values(ds[VARIABLE])\n",
    "    ds = clean_time_attrs(ds)\n",
    "    ds = ds.chunk({'time': -1, **CHUNKS_LATLON})\n",
    "\n",
    "    _print_stats(label, ds[VARIABLE])\n",
    "    return ds\n",
    "\n",
    "# =============================================================================\n",
    "# 5. BIAS CORRECTION\n",
    "# =============================================================================\n",
    "\n",
    "def train_qdm(ref_da, hist_da):\n",
    "    \"\"\"\n",
    "    Train a Quantile Delta Mapping transfer function.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    ref_da  : xr.DataArray – observational reference (baseline period)\n",
    "    hist_da : xr.DataArray – historical model simulation regridded to ref grid\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    Trained sdba.QuantileDeltaMapping object.\n",
    "\n",
    "    Scientific note\n",
    "    ---------------\n",
    "    The transfer function is derived solely from the calibration (baseline)\n",
    "    period.  It is then applied to any future period of any scenario, which is\n",
    "    the standard QDM workflow (Cannon et al. 2015).  Training only once per\n",
    "    model means the correction is scenario-independent – correct behaviour.\n",
    "    \"\"\"\n",
    "    return sdba.QuantileDeltaMapping.train(\n",
    "        ref=ref_da.chunk({'time': -1}),\n",
    "        hist=hist_da.chunk({'time': -1}),\n",
    "        nquantiles=NQUANTILES,\n",
    "        group=QDM_GROUP,\n",
    "        kind=QDM_KIND,\n",
    "    )\n",
    "\n",
    "\n",
    "def apply_qdm(qdm_obj, fut_da):\n",
    "    \"\"\"Apply a pre-trained QDM to a future DataArray.\"\"\"\n",
    "    corrected = qdm_obj.adjust(fut_da.chunk({'time': -1}))\n",
    "    corrected = clean_values(corrected)\n",
    "    corrected.attrs['units'] = REF_UNITS\n",
    "    return corrected\n",
    "\n",
    "# =============================================================================\n",
    "# 6. WET-DAY FREQUENCY ADJUSTMENT  (precipitation only)\n",
    "# =============================================================================\n",
    "\n",
    "def adjust_wet_day_frequency(ref_da, sim_da, thresh=WET_THRESH):\n",
    "    \"\"\"\n",
    "    Adjust the wet-day frequency of *sim_da* to match *ref_da*.\n",
    "\n",
    "    Algorithm (Themeßl et al. 2012)\n",
    "    --------------------------------\n",
    "    For each calendar month:\n",
    "      1. Compute the wet-day fraction in the reference (f_ref) and in the\n",
    "         bias-corrected simulation (f_sim).\n",
    "      2. If f_sim > f_ref, zero out the smallest (f_sim − f_ref) × N wet\n",
    "         events in the simulation, where N is the number of days in that month\n",
    "         across all years.\n",
    "\n",
    "    Scientific note\n",
    "    ---------------\n",
    "    *ref_da* must be the OBSERVED reference (baseline period), NOT the\n",
    "    bias-corrected future.  The target wet-day frequency is a climatological\n",
    "    property of the reference dataset, not of the projected future climate.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    ref_da : xr.DataArray – observed reference (baseline period, mm day-1)\n",
    "    sim_da : xr.DataArray – bias-corrected future simulation (mm day-1)\n",
    "    thresh : float        – wet-day threshold (default 0.1 mm day-1)\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    xr.DataArray with adjusted wet-day frequency.\n",
    "    \"\"\"\n",
    "    if not WET_ADJUST:\n",
    "        return sim_da\n",
    "\n",
    "    ref_da = clean_values(ref_da).transpose('time', ...)\n",
    "    sim_da = clean_values(sim_da).transpose('time', ...)\n",
    "    adjusted = sim_da.copy(deep=True)\n",
    "\n",
    "    for month, ref_month in ref_da.groupby('time.month'):\n",
    "        sim_month = sim_da.sel(time=sim_da['time.month'] == month)\n",
    "        if len(sim_month.time) == 0:\n",
    "            continue\n",
    "\n",
    "        n_sim_days  = len(sim_month.time)\n",
    "\n",
    "        # Wet-day fraction in the REFERENCE (target)\n",
    "        ref_wet_frac = (ref_month >= thresh).mean(dim='time', skipna=True)\n",
    "\n",
    "        # Wet-day fraction in the SIMULATION\n",
    "        sim_wet_frac = (sim_month >= thresh).mean(dim='time', skipna=True)\n",
    "\n",
    "        # Number of excess wet days to remove\n",
    "        target_wet_days = np.round(ref_wet_frac * n_sim_days).astype(int)\n",
    "        actual_wet_days = (sim_month >= thresh).sum(dim='time', skipna=True)\n",
    "        n_remove = (actual_wet_days - target_wet_days).clip(min=0)\n",
    "        n_remove = xr.where(np.isfinite(ref_wet_frac), n_remove, 0)\n",
    "\n",
    "        def _zero_smallest_wet(pixel_values, n_to_remove):\n",
    "            \"\"\"Zero out the n_to_remove smallest wet events in a 1-D pixel.\"\"\"\n",
    "            arr = np.array(pixel_values, copy=True)\n",
    "            n   = int(n_to_remove)\n",
    "            if n <= 0 or np.all(np.isnan(arr)):\n",
    "                return arr\n",
    "            wet_idx = np.where((arr >= thresh) & np.isfinite(arr))[0]\n",
    "            if len(wet_idx) == 0:\n",
    "                return arr\n",
    "            # Sort ascending; zero the smallest wet events first\n",
    "            sorted_wet = wet_idx[np.argsort(arr[wet_idx])]\n",
    "            arr[sorted_wet[:n]] = 0.0\n",
    "            return arr\n",
    "\n",
    "        adjusted_month = xr.apply_ufunc(\n",
    "            _zero_smallest_wet,\n",
    "            sim_month,\n",
    "            n_remove,\n",
    "            input_core_dims=[['time'], []],\n",
    "            output_core_dims=[['time']],\n",
    "            vectorize=True,\n",
    "            dask='parallelized',\n",
    "            output_dtypes=[sim_month.dtype],\n",
    "            dask_gufunc_kwargs={'output_sizes': {'time': n_sim_days}},\n",
    "        )\n",
    "        adjusted.loc[dict(time=sim_month.time)] = adjusted_month\n",
    "\n",
    "    return adjusted\n",
    "\n",
    "# =============================================================================\n",
    "# 7. ENSEMBLE STATISTICS\n",
    "# =============================================================================\n",
    "\n",
    "def build_ensemble_stats(corrected_paths, scenario, interval_name):\n",
    "    \"\"\"Load individual model files and compute ensemble mean/median/p10/p90.\"\"\"\n",
    "    import dask\n",
    "    dask.config.set(scheduler='synchronous')\n",
    "\n",
    "    print(f\"\\n   Building ensemble from {len(corrected_paths)} models …\")\n",
    "    arrays = []\n",
    "    for p in corrected_paths:\n",
    "        # Use load_dataset (fully in-memory) to avoid LRU file-handle cache\n",
    "        # eviction errors that occur when re-opening lazy dask arrays on\n",
    "        # Google Drive after a long pipeline run.\n",
    "        ds_tmp = xr.load_dataset(p)\n",
    "        var_name = [v for v in ds_tmp.data_vars][0]\n",
    "        arrays.append(ds_tmp[var_name])\n",
    "    ensemble = xr.concat(arrays, dim='model')\n",
    "    ensemble.attrs['units'] = REF_UNITS\n",
    "\n",
    "    ens_mean   = ensemble.mean(dim='model',   skipna=True)\n",
    "    ens_median = ensemble.median(dim='model', skipna=True)\n",
    "    ens_p10    = ensemble.quantile(0.10, dim='model', skipna=True).drop_vars('quantile')\n",
    "    ens_p90    = ensemble.quantile(0.90, dim='model', skipna=True).drop_vars('quantile')\n",
    "\n",
    "    ds_stats = xr.Dataset({\n",
    "        f'{VARIABLE}_mean':   ens_mean,\n",
    "        f'{VARIABLE}_median': ens_median,\n",
    "        f'{VARIABLE}_p10':    ens_p10,\n",
    "        f'{VARIABLE}_p90':    ens_p90,\n",
    "    })\n",
    "    for v in ds_stats.data_vars:\n",
    "        ds_stats[v].attrs['units'] = REF_UNITS\n",
    "\n",
    "    ds_stats = clean_time_attrs(ds_stats)\n",
    "\n",
    "    # Full stats file\n",
    "    stats_path = os.path.join(\n",
    "        OUTPUT_DIR, f\"qdm_ensemble_stats_{VARIABLE}_{scenario}_{interval_name}.nc\"\n",
    "    )\n",
    "    ds_stats.to_netcdf(stats_path)\n",
    "    print(f\"   ✅ Ensemble stats → {stats_path}\")\n",
    "\n",
    "    # Convenience files\n",
    "    for name, da in [('mean', ens_mean), ('median', ens_median)]:\n",
    "        p = os.path.join(\n",
    "            OUTPUT_DIR, f\"qdm_ensemble_{name}_{VARIABLE}_{scenario}_{interval_name}.nc\"\n",
    "        )\n",
    "        clean_time_attrs(da).to_netcdf(p)\n",
    "\n",
    "# =============================================================================\n",
    "# 8. UTILITIES\n",
    "# =============================================================================\n",
    "\n",
    "def _print_stats(label, da):\n",
    "    try:\n",
    "        vmin  = float(da.min().values)\n",
    "        vmax  = float(da.max().values)\n",
    "        vmean = float(da.mean().values)\n",
    "        print(f\"      [{label}] shape={da.shape}  \"\n",
    "              f\"min={vmin:.3f}  max={vmax:.3f}  mean={vmean:.3f}  \"\n",
    "              f\"units={da.attrs.get('units', '?')}\")\n",
    "    except Exception:\n",
    "        print(f\"      [{label}] shape={da.shape}\")\n",
    "\n",
    "# =============================================================================\n",
    "# 9. MAIN\n",
    "# =============================================================================\n",
    "\n",
    "def main():\n",
    "    # ── 9a. Fetch reference ONCE ──────────────────────────────────────────────\n",
    "    print(\"\\n\" + \"=\"*65)\n",
    "    print(f\"STEP 1  Fetch reference dataset ({REF_NAME}) – baseline only\")\n",
    "    print(\"=\"*65)\n",
    "    ds_ref = fetch_reference()   # reused for ALL model × scenario × interval\n",
    "\n",
    "    # ── 9b. Fetch historical CMIP6 ONCE per model ─────────────────────────────\n",
    "    print(\"\\n\" + \"=\"*65)\n",
    "    print(\"STEP 2  Fetch & preprocess historical CMIP6 (once per model)\")\n",
    "    print(\"=\"*65)\n",
    "    hist_cache = {}   # {model: xr.Dataset}  – avoids re-fetching for each scenario\n",
    "    for model in MODELS:\n",
    "        try:\n",
    "            ds_hist = fetch_cmip6_historical(model)\n",
    "            hist_cache[model] = ds_hist\n",
    "        except Exception as exc:\n",
    "            print(f\"   ⚠️  Could not fetch historical data for {model}: {exc}\")\n",
    "\n",
    "    # ── 9c. Train QDM ONCE per model ──────────────────────────────────────────\n",
    "    print(\"\\n\" + \"=\"*65)\n",
    "    print(\"STEP 3  Train QDM transfer function (once per model)\")\n",
    "    print(\"=\"*65)\n",
    "    qdm_cache = {}   # {model: trained QDM object}\n",
    "    for model, ds_hist in hist_cache.items():\n",
    "        print(f\"   Training QDM for {model} …\")\n",
    "        da_hist_regrid = regrid_to_reference(ds_hist[VARIABLE], ds_ref['ref'])\n",
    "        qdm_cache[model] = train_qdm(\n",
    "            ref_da=ds_ref['ref'],\n",
    "            hist_da=da_hist_regrid,\n",
    "        )\n",
    "        print(f\"   ✅ QDM trained for {model}\")\n",
    "\n",
    "    # ── 9d. Apply QDM to every scenario × future interval ────────────────────\n",
    "    print(\"\\n\" + \"=\"*65)\n",
    "    print(\"STEP 4  Apply QDM to future periods\")\n",
    "    print(\"=\"*65)\n",
    "    for scenario in SCENARIOS:\n",
    "        for fut_start, fut_end, interval_name in FUTURE_INTERVALS:\n",
    "            tag = f\"{scenario.upper()} | {interval_name}\"\n",
    "            print(f\"\\n{'─'*55}\")\n",
    "            print(f\"  {tag}\")\n",
    "            print(f\"{'─'*55}\")\n",
    "\n",
    "            corrected_paths = []\n",
    "\n",
    "            for model in MODELS:\n",
    "                if model not in qdm_cache:\n",
    "                    print(f\"   ⏭️  Skipping {model} (no QDM available)\")\n",
    "                    continue\n",
    "\n",
    "                print(f\"\\n   Model: {model}\")\n",
    "                try:\n",
    "                    # Fetch future data for this specific scenario/interval\n",
    "                    ds_fut = fetch_cmip6_future(\n",
    "                        model, scenario, fut_start, fut_end, interval_name\n",
    "                    )\n",
    "                except Exception as exc:\n",
    "                    print(f\"      ⚠️  Fetch failed: {exc}\")\n",
    "                    continue\n",
    "\n",
    "                # Regrid future to reference grid\n",
    "                da_fut_regrid = regrid_to_reference(ds_fut[VARIABLE], ds_ref['ref'])\n",
    "\n",
    "                # Apply the pre-trained QDM  ← no re-training here\n",
    "                fut_corr = apply_qdm(qdm_cache[model], da_fut_regrid)\n",
    "\n",
    "                # Wet-day frequency adjustment (precipitation only)\n",
    "                # Ref: Themeßl et al. 2012 – uses OBSERVED ref stats, not future\n",
    "                if WET_ADJUST:\n",
    "                    print(f\"      Adjusting wet-day frequency …\")\n",
    "                    fut_corr = adjust_wet_day_frequency(\n",
    "                        ref_da=ds_ref['ref'],   # ← observed reference\n",
    "                        sim_da=fut_corr,\n",
    "                        thresh=WET_THRESH,\n",
    "                    )\n",
    "                    # Clip negative residuals introduced by zeroing\n",
    "                    fut_corr = xr.where(fut_corr < 0.0, 0.0, fut_corr)\n",
    "                    fut_corr = clean_values(fut_corr)\n",
    "                    fut_corr.attrs['units'] = REF_UNITS\n",
    "\n",
    "                fut_corr = clean_time_attrs(fut_corr)\n",
    "\n",
    "                out_path = os.path.join(\n",
    "                    OUTPUT_DIR,\n",
    "                    f\"qdm_{VARIABLE}_{model}_{scenario}_{interval_name}.nc\",\n",
    "                )\n",
    "                # Materialise all lazy dask computations before writing so the\n",
    "                # file handle is fully flushed and closed – prevents LRU cache\n",
    "                # eviction errors when re-opening the file for ensemble building.\n",
    "                fut_corr.load().to_netcdf(out_path)\n",
    "                print(f\"      💾 Saved: {out_path}\")\n",
    "                corrected_paths.append(out_path)\n",
    "\n",
    "            # Build ensemble statistics for this scenario/interval\n",
    "            if corrected_paths:\n",
    "                build_ensemble_stats(corrected_paths, scenario, interval_name)\n",
    "            else:\n",
    "                print(f\"   ❌ No models succeeded for {tag}\")\n",
    "\n",
    "    print(\"\\n\" + \"=\"*65)\n",
    "    print(f\"🎉 PIPELINE COMPLETE – outputs in {OUTPUT_DIR}\")\n",
    "    print(\"=\"*65)\n",
    "\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    main()"
   ]
